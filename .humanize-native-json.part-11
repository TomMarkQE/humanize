\nFailed: %d\\n' \"$PASSED\" \"$FAILED\"\n[[ \"$FAILED\" -eq 0 ]]\n"},{"path":"tests/test-codex-native-runtime.sh","mode":493,"content":"#!/usr/bin/env bash\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]:-$0}\")\" && pwd)\"\nPROJECT_ROOT=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\nRUNTIME=\"$PROJECT_ROOT/scripts/native-rlcr.py\"\nPASSED=0\nFAILED=0\n\npass() {\n    printf 'PASS: %s\\n' \"$1\"\n    PASSED=$((PASSED + 1))\n}\n\nfail() {\n    printf 'FAIL: %s\\n  Expected: %s\\n  Got: %s\\n' \"$1\" \"${2:-}\" \"${3:-}\" >&2\n    FAILED=$((FAILED + 1))\n}\n\nassert_eq() {\n    description=\"$1\"\n    expected=\"$2\"\n    actual=\"$3\"\n    if [[ \"$actual\" == \"$expected\" ]]; then\n        pass \"$description\"\n    else\n        fail \"$description\" \"$expected\" \"$actual\"\n    fi\n}\n\njson_get() {\n    python3 -c 'import json,sys; data=json.load(open(sys.argv[1])); value=data; [None for key in sys.argv[2].split(\".\") if not (value := value.get(key) if isinstance(value, dict) else None)]; print(\"\" if value is None else str(value).lower() if isinstance(value, bool) else value)' \"$1\" \"$2\"\n}\n\nrun_capture() {\n    output_file=\"$1\"\n    shift\n    set +e\n    \"$@\" >\"$output_file\" 2>&1\n    CAPTURE_EXIT=$?\n    set -e\n}\n\ninit_repo() {\n    repo=\"$1\"\n    mkdir -p \"$repo\"\n    git -C \"$repo\" init -q\n    git -C \"$repo\" config user.email test@example.com\n    git -C \"$repo\" config user.name 'Humanize Test'\n    git -C \"$repo\" config commit.gpgsign false\n    cat > \"$repo/.gitignore\" <<'EOF'\n.humanize/\nEOF\n    cat > \"$repo/plan.md\" <<'EOF'\n# Native Agent Migration\n\nImplement the requested behavior with deterministic tests.\n\n## Acceptance Criteria\n- The implementation behaves correctly.\n- Independent review contracts are satisfied.\nEOF\n    printf 'initial\\n' > \"$repo/app.txt\"\n    git -C \"$repo\" add .gitignore plan.md app.txt\n    git -C \"$repo\" -c commit.gpgsign=false commit -q -m initial\n}\n\nwrite_summary() {\n    path=\"$1\"\n    round=\"$2\"\n    cat > \"$path\" <<EOF\n# Humanize Round $round Summary\n\n## Work Completed\n\n- Implemented the bounded round objective and recorded the resulting behavior.\n\n## Files Changed\n\n- app.txt\n\n## Validation\n\n- test command completed successfully.\n\n## Remaining Items\n\n- None.\nEOF\n}\n\nTMP_ROOT=\"$(mktemp -d)\"\ntrap 'rm -rf \"$TMP_ROOT\"' EXIT\n\nif [[ -x \"$RUNTIME\" ]]; then\n    pass \"native runtime is executable\"\nelse\n    fail \"native runtime is executable\" \"$RUNTIME\" \"missing or not executable\"\nfi\n\nif grep -Eq 'subprocess\\.(run|Popen).*codex|[\"'\"']codex[\"'\"'][[:space:]]*,[[:space:]]*[\"'\"'](exec|review)' \"$RUNTIME\"; then\n    fail \"deterministic runtime contains no model CLI invocation\" \"no codex subprocess\" \"match found\"\nelse\n    pass \"deterministic runtime contains no model CLI invocation\"\nfi\n\nREPO_DIRTY=\"$TMP_ROOT/repo-dirty-start\"\ninit_repo \"$REPO_DIRTY\"\nprintf 'preexisting change\\n' >> \"$REPO_DIRTY/app.txt\"\nrun_capture \"$TMP_ROOT/init-dirty.json\" python3 \"$RUNTIME\" init \\\n    --project-root \"$REPO_DIRTY\" --plan-file plan.md \\\n    --loop-dir \"$REPO_DIRTY/.humanize/rlcr/dirty-start\"\nif [[ \"$CAPTURE_EXIT\" -ne 0 ]]; then\n    pass \"init rejects a pre-existing dirty project tree\"\nelse\n    fail \"init rejects a pre-existing dirty project tree\" \"non-zero\" \"0\"\nfi\nassert_eq \"dirty init reports an explicit error\" \"working_tree_dirty\" \"$(json_get \"$TMP_ROOT/init-dirty.json\" error.code)\"\n\nREPO_UNTRACKED_PLAN=\"$TMP_ROOT/repo-untracked-plan\"\ninit_repo \"$REPO_UNTRACKED_PLAN\"\ngit -C \"$REPO_UNTRACKED_PLAN\" rm -q --cached plan.md\ngit -C \"$REPO_UNTRACKED_PLAN\" -c commit.gpgsign=false commit -q -m 'leave plan untracked'\nrun_capture \"$TMP_ROOT/init-untracked.json\" python3 \"$RUNTIME\" init \\\n    --project-root \"$REPO_UNTRACKED_PLAN\" --plan-file plan.md \\\n    --loop-dir \"$REPO_UNTRACKED_PLAN/.humanize/rlcr/untracked\"\nassert_eq \"init permits an untracked source plan as the sole dirty path\" \"0\" \"$CAPTURE_EXIT\"\nUNTRACKED_LOOP=\"$(json_get \"$TMP_ROOT/init-untracked.json\" loop_dir)\"\nrun_capture \"$TMP_ROOT/validate-untracked.json\" python3 \"$RUNTIME\" validate --loop-dir \"$UNTRACKED_LOOP\"\nassert_eq \"untracked source plan remains excluded from worker cleanliness checks\" \"0\" \"$CAPTURE_EXIT\"\n\nREPO_CORRUPT=\"$TMP_ROOT/repo-corrupt-state\"\ninit_repo \"$REPO_CORRUPT\"\nmkdir -p \"$REPO_CORRUPT/.humanize/rlcr/corrupt\"\nprintf '{not-json\\n' > \"$REPO_CORRUPT/.humanize/rlcr/corrupt/state.json\"\nrun_capture \"$TMP_ROOT/init-corrupt.json\" python3 \"$RUNTIME\" init \\\n    --project-root \"$REPO_CORRUPT\" --plan-file plan.md \\\n    --loop-dir \"$REPO_CORRUPT/.humanize/rlcr/new-loop\"\nif [[ \"$CAPTURE_EXIT\" -ne 0 ]]; then\n    pass \"init fails closed when an existing native state file is corrupt\"\nelse\n    fail \"init fails closed when an existing native state file is corrupt\" \"non-zero\" \"0\"\nfi\nassert_eq \"corrupt prior state is reported explicitly\" \"state_corrupt\" \"$(json_get \"$TMP_ROOT/init-corrupt.json\" error.code)\"\n\nREPO_CONCURRENT=\"$TMP_ROOT/repo-concurrent-init\"\ninit_repo \"$REPO_CONCURRENT\"\nset +e\npython3 \"$RUNTIME\" init --project-root \"$REPO_CONCURRENT\" --plan-file plan.md \\\n    --loop-dir \"$REPO_CONCURRENT/.humanize/rlcr/first\" > \"$TMP_ROOT/concurrent-first.json\" 2>&1 &\nfirst_pid=$!\npython3 \"$RUNTIME\" init --project-root \"$REPO_CONCURRENT\" --plan-file plan.md \\\n    --loop-dir \"$REPO_CONCURRENT/.humanize/rlcr/second\" > \"$TMP_ROOT/concurrent-second.json\" 2>&1 &\nsecond_pid=$!\nwait \"$first_pid\"; first_exit=$?\nwait \"$second_pid\"; second_exit=$?\nset -e\nif { [[ \"$first_exit\" -eq 0 && \"$second_exit\" -ne 0 ]]; } || { [[ \"$second_exit\" -eq 0 && \"$first_exit\" -ne 0 ]]; }; then\n    pass \"project lock permits exactly one concurrent native loop initialization\"\nelse\n    fail \"project lock permits exactly one concurrent native loop initialization\" \"one success and one failure\" \"$first_exit,$second_exit\"\nfi\nif [[ \"$first_exit\" -ne 0 ]]; then\n    concurrent_failure=\"$TMP_ROOT/concurrent-first.json\"\nelse\n    concurrent_failure=\"$TMP_ROOT/concurrent-second.json\"\nfi\nassert_eq \"concurrent loser observes the active loop instead of racing state\" \"loop_already_active\" \"$(json_get \"$concurrent_failure\" error.code)\"\n\nREPO=\"$TMP_ROOT/repo\"\ninit_repo \"$REPO\"\nINIT_JSON=\"$TMP_ROOT/init.json\"\nrun_capture \"$INIT_JSON\" python3 \"$RUNTIME\" init \\\n    --project-root \"$REPO\" \\\n    --plan-file plan.md \\\n    --track-plan-file \\\n    --max-rounds 5 \\\n    --loop-dir \"$REPO/.humanize/rlcr/native-test\"\nassert_eq \"init succeeds\" \"0\" \"$CAPTURE_EXIT\"\nassert_eq \"init selects native engine action\" \"delegate_worker\" \"$(json_get \"$INIT_JSON\" next_action)\"\nLOOP_DIR=\"$(json_get \"$INIT_JSON\" loop_dir)\"\nSTATE_FILE=\"$LOOP_DIR/state.json\"\nassert_eq \"state records codex-native engine\" \"codex-native\" \"$(json_get \"$STATE_FILE\" engine)\"\nassert_eq \"state starts in implementation phase\" \"implementation\" \"$(json_get \"$STATE_FILE\" phase)\"\n\nwrite_summary \"$LOOP_DIR/round-0-summary.md\" 0\nprintf 'dirty\\n' >> \"$REPO/app.txt\"\nDIRTY_JSON=\"$TMP_ROOT/dirty.json\"\nrun_capture \"$DIRTY_JSON\" python3 \"$RUNTIME\" checkpoint --loop-dir \"$LOOP_DIR\"\nif [[ \"$CAPTURE_EXIT\" -ne 0 ]]; then\n    pass \"checkpoint rejects an uncommitted worker tree\"\nelse\n    fail \"checkpoint rejects an uncommitted worker tree\" \"non-zero\" \"0\"\nfi\nassert_eq \"dirty checkpoint explains failure\" \"working_tree_dirty\" \"$(json_get \"$DIRTY_JSON\" error.code)\"\n\ngit -C \"$REPO\" add app.txt\ngit -C \"$REPO\" -c commit.gpgsign=false commit -q -m 'round zero'\nCHECKPOINT_JSON=\"$TMP_ROOT/checkpoint.json\"\nrun_capture \"$CHECKPOINT_JSON\" python3 \"$RUNTIME\" checkpoint --loop-dir \"$LOOP_DIR\"\nassert_eq \"valid checkpoint succeeds\" \"0\" \"$CAPTURE_EXIT\"\nassert_eq \"checkpoint requests independent implementation review\" \"delegate_implementation_reviewer\" \"$(json_get \"$CHECKPOINT_JSON\" next_action)\"\n\nSTATE_BEFORE=\"$(sha256sum \"$STATE_FILE\" | awk '{print $1}')\"\ncat > \"$LOOP_DIR/bad-review.md\" <<'EOF'\nThis response omitted the required stable markers.\nEOF\nBAD_REVIEW_JSON=\"$TMP_ROOT/bad-review.json\"\nrun_capture \"$BAD_REVIEW_JSON\" python3 \"$RUNTIME\" record-review \\\n    --loop-dir \"$LOOP_DIR\" --kind implementation --review-file \"$LOOP_DIR/bad-review.md\"\nif [[ \"$CAPTURE_EXIT\" -ne 0 ]]; then\n    pass \"malformed implementation review fails closed\"\nelse\n    fail \"malformed implementation review fails closed\" \"non-zero\" \"0\"\nfi\nassert_eq \"malformed review reports contract error\" \"review_contract_invalid\" \"$(json_get \"$BAD_REVIEW_JSON\" error.code)\"\nassert_eq \"malformed review leaves state unchanged\" \"$STATE_BEFORE\" \"$(sha256sum \"$STATE_FILE\" | awk '{print $1}')\"\n\ncat > \"$LOOP_DIR/impl-review-0.md\" <<'EOF'\nHUMANIZE_IMPLEMENTATION_REVIEW: continue\nMAINLINE_PROGRESS: advanced\nThe mainline advanced, but one acceptance criterion still needs direct evidence.\nEOF\nCONTINUE_JSON=\"$TMP_ROOT/continue.json\"\nrun_capture \"$CONTINUE_JSON\" python3 \"$RUNTIME\" record-review \\\n    --loop-dir \"$LOOP_DIR\" --kind implementation --review-file \"$LOOP_DIR/impl-review-0.md\"\nassert_eq \"continue review succeeds\" \"0\" \"$CAPTURE_EXIT\"\nassert_eq \"continue review advances round\" \"1\" \"$(json_get \"$CONTINUE_JSON\" round)\"\nassert_eq \"continue review returns to worker\" \"delegate_worker\" \"$(json_get \"$CONTINUE_JSON\" next_action)\"\n\nprintf 'round-one\\n' >> \"$REPO/app.txt\"\ngit -C \"$REPO\" add app.txt\ngit -C \"$REPO\" -c commit.gpgsign=false commit -q -m 'round one'\nwrite_summary \"$LOOP_DIR/round-1-summary.md\" 1\nrun_capture \"$TMP_ROOT/checkpoint-1.json\" python3 \"$RUNTIME\" checkpoint --loop-dir \"$LOOP_DIR\"\nassert_eq \"second checkpoint succeeds\" \"0\" \"$CAPTURE_EXIT\"\n\ncat > \"$LOOP_DIR/impl-review-contradictory.md\" <<'EOF'\nHUMANIZE_IMPLEMENTATION_REVIEW: complete\nMAINLINE_PROGRESS: stalled\nThe verdict and progress marker contradict one another.\nEOF\nrun_capture \"$TMP_ROOT/complete-contradictory.json\" python3 \"$RUNTIME\" record-review \\\n    --loop-dir \"$LOOP_DIR\" --kind implementation --review-file \"$LOOP_DIR/impl-review-contradictory.md\"\nif [[ \"$CAPTURE_EXIT\" -ne 0 ]]; then\n    pass \"contradictory implementation completion fails closed\"\nelse\n    fail \"contradictory implementation completion fails closed\" \"non-zero\" \"0\"\nfi\nassert_eq \"contradictory completion reports a contract error\" \"review_contract_invalid\" \"$(json_get \"$TMP_ROOT/complete-contradictory.json\" error.code)\"\n\ncat > \"$LOOP_DIR/impl-review-1.md\" <<'EOF'\nHUMANIZE_IMPLEMENTATION_REVIEW: complete\nMAINLINE_PROGRESS: advanced\nAll plan acceptance criteria now have implementation and test evidence.\nEOF\nrun_capture \"$TMP_ROOT/complete-impl.json\" python3 \"$RUNTIME\" record-review \\\n    --loop-dir \"$LOOP_DIR\" --kind implementation --review-file \"$LOOP_DIR/impl-review-1.md\"\nassert_eq \"implementation complete transition succeeds\" \"0\" \"$CAPTURE_EXIT\"\nassert_eq \"implementation complete moves to code review\" \"code_review\" \"$(json_get \"$TMP_ROOT/complete-impl.json\" phase)\"\n\ncat > \"$LOOP_DIR/code-bad.md\" <<'EOF'\nHUMANIZE_CODE_REVIEW: changes_required\nA finding exists but has no priority contract marker.\nEOF\nrun_capture \"$TMP_ROOT/code-bad.json\" python3 \"$RUNTIME\" record-review \\\n    --loop-dir \"$LOOP_DIR\" --kind code --review-file \"$LOOP_DIR/code-bad.md\"\nif [[ \"$CAPTURE_EXIT\" -ne 0 ]]; then\n    pass \"changes_required without priority marker fails closed\"\nelse\n    fail \"changes_required without priority marker fails closed\" \"non-zero\" \"0\"\nfi\nassert_eq \"invalid code review reports contract error\" \"review_contract_invalid\"